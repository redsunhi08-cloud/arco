{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer consultation inquiry",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "projectType": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Newsletter subscription",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Customer inquiries"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Newsletter subscriptions"
    }
  }
}
